SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
ALLOWED_ORIGINS=http://localhost:5174

# Auth admin
ADMIN_EMAIL=admin@notifflow.com
ADMIN_PASSWORD_HASH=           # python3 -c "import bcrypt; print(bcrypt.hashpw(b'MotDePasse', bcrypt.gensalt()).decode())"
JWT_SECRET=change-this-long-random-secret
JWT_EXPIRE_MINUTES=480

# Email — Resend (resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM_NAME=Votre Boutique
EMAIL_FROM_ADDRESS=notifications@votredomaine.com
EMAIL_REPLY_TO=support@votredomaine.com
UNSUBSCRIBE_URL=https://votredomaine.com/unsubscribe

# SMS — Twilio (twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+33XXXXXXXXX

# Envoi par batch (anti-spam)
BATCH_SIZE=20
BATCH_DELAY_SECONDS=2.0
